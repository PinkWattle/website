---
import { SITE, NAV_LINKS, SOCIAL_LINKS } from '../config';
const year = new Date().getFullYear();

// Inline SVG path data for each supported social icon.
const ICONS: Record<string, string> = {
  facebook:
    'M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.45 2.89h-2.33v6.99A10 10 0 0 0 22 12Z',
  instagram:
    'M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23a3.72 3.72 0 0 1-.9 1.38c-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.72 3.72 0 0 1-1.38-.9 3.72 3.72 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16Zm0 1.62c-3.15 0-3.5.01-4.74.07-.97.04-1.5.21-1.85.34-.46.18-.8.4-1.15.74-.34.35-.56.69-.74 1.15-.13.35-.3.88-.34 1.85-.06 1.24-.07 1.59-.07 4.74s.01 3.5.07 4.74c.04.97.21 1.5.34 1.85.18.46.4.8.74 1.15.35.34.69.56 1.15.74.35.13.88.3 1.85.34 1.24.06 1.59.07 4.74.07s3.5-.01 4.74-.07c.97-.04 1.5-.21 1.85-.34.46-.18.8-.4 1.15-.74.34-.35.56-.69.74-1.15.13-.35.3-.88.34-1.85.06-1.24.07-1.59.07-4.74s-.01-3.5-.07-4.74c-.04-.97-.21-1.5-.34-1.85a3.1 3.1 0 0 0-.74-1.15 3.1 3.1 0 0 0-1.15-.74c-.35-.13-.88-.3-1.85-.34-1.24-.06-1.59-.07-4.74-.07Zm0 2.76a5.46 5.46 0 1 1 0 10.92 5.46 5.46 0 0 1 0-10.92Zm0 9a3.54 3.54 0 1 0 0-7.08 3.54 3.54 0 0 0 0 7.08Zm5.68-9.21a1.27 1.27 0 1 1-2.55 0 1.27 1.27 0 0 1 2.55 0Z',
  linkedin:
    'M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14Zm1.78 13.02H3.55V9h3.57v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z',
};

const socials = SOCIAL_LINKS.filter((s) => ICONS[s.icon]);
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <img src="/images/logo.svg" alt="Pink Wattle Occupational Therapy" width="200" height="50" />
      <p>
        Mobile occupational therapy across {SITE.location}. Supporting NDIS and
        private clients, from paediatrics through to adults.
      </p>

      {
        socials.length > 0 && (
          <ul class="social-list" aria-label="Social media">
            {socials.map((social) => (
              <li>
                <a
                  href={social.href}
                  aria-label={social.label}
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                    <path d={ICONS[social.icon]} />
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>

    <nav class="footer-nav" aria-label="Footer">
      <h2>Explore</h2>
      <ul>
        {NAV_LINKS.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
      </ul>
    </nav>

    <div class="footer-contact">
      <h2>Get in touch</h2>
      <p>
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </p>
      <p>{SITE.location}</p>
      <a href="/contact" class="btn btn--outline footer-cta">Contact us</a>
    </div>
  </div>

  <div class="footer-bar">
    <div class="container">
      <p>© {year} {SITE.name} {SITE.tagline}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-white);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.2fr;
    gap: 2.5rem;
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .footer-brand img {
    height: 46px;
    width: auto;
    margin-bottom: 1rem;
  }

  .footer-brand p {
    color: var(--color-text-muted);
    max-width: 38ch;
  }

  .social-list {
    list-style: none;
    padding: 0;
    margin-top: 1.25rem;
    display: flex;
    gap: 0.75rem;
  }

  .social-list a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    color: var(--color-primary);
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    transition: background-color var(--transition), color var(--transition),
      transform var(--transition);
  }

  .social-list a:hover {
    background-color: var(--color-primary);
    color: var(--color-white);
    transform: translateY(-2px);
  }

  .site-footer h2 {
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .footer-nav ul {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }

  .footer-nav a {
    color: var(--color-text);
    font-weight: 500;
  }

  .footer-nav a:hover {
    color: var(--color-primary);
  }

  .footer-contact p {
    margin-bottom: 0.5rem;
    color: var(--color-text-muted);
  }

  .footer-cta {
    margin-top: 1rem;
    padding: 0.6rem 1.2rem;
  }

  .footer-bar {
    border-top: 1px solid var(--color-border);
    background-color: var(--color-background);
  }

  .footer-bar p {
    padding-block: 1.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  @media (max-width: 760px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
