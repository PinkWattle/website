---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config';

const services = [
  {
    title: 'Paediatric OT',
    body: 'Supporting children to build the skills they need for play, learning and everyday independence — at home, in childcare and at school.',
  },
  {
    title: 'Adult & adolescent therapy',
    body: 'Practical, goal-focused support for teens and adults to participate confidently in daily life, study, work and the community.',
  },
  {
    title: 'Daily living skills',
    body: 'Building independence in self-care, routines, cooking and the everyday activities that matter most to you and your family.',
  },
  {
    title: 'Sensory & regulation support',
    body: 'Strategies to understand sensory needs and support emotional regulation across home, school and work environments.',
  },
  {
    title: 'Assistive technology & equipment',
    body: 'Assessment, prescription and trials of equipment and assistive technology to make everyday tasks safer and easier.',
  },
  {
    title: 'Home & environment assessments',
    body: 'Reviewing your spaces and recommending modifications that improve safety, access and independence.',
  },
];

const steps = [
  {
    title: 'Get in touch',
    body: 'Send us a message or email. We’ll talk through your situation and what you’re hoping to achieve.',
  },
  {
    title: 'We come to you',
    body: 'One of our therapists meets you in the environment that matters — your home, school or workplace.',
  },
  {
    title: 'A plan that fits',
    body: 'Together we set goals and create a practical, personalised therapy plan with clear next steps.',
  },
];

// PLACEHOLDER testimonials — replace the quotes and names with real,
// consented client feedback before going live.
const testimonials = [
  {
    quote:
      'The team made my son feel comfortable from the very first session at home. We’ve seen real progress with his daily routines.',
    name: 'Placeholder — Parent of a paediatric client',
  },
  {
    quote:
      'Having therapy in my own workplace made all the difference. Practical, friendly and genuinely tailored to my goals.',
    name: 'Placeholder — Adult NDIS participant',
  },
  {
    quote:
      'Responsive, professional and easy to work with. They took the time to understand exactly what we needed.',
    name: 'Placeholder — Private client',
  },
];
---

<BaseLayout>
  <!-- ============================= HERO ============================= -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="tag">NDIS &amp; private clients welcome</span>
        <h1>Occupational therapy that comes to you</h1>
        <p class="hero-lead">
          Pink Wattle is a mobile occupational therapy provider based in
          {SITE.location}. Our experienced therapists work where you live, learn
          and work — supporting clients from paediatrics through to adults across
          all OT disciplines.
        </p>
        <div class="hero-actions">
          <a href="/contact" class="btn btn--primary">Get in touch</a>
          <a href="/#services" class="btn btn--outline">Explore our services</a>
        </div>
        <ul class="hero-points">
          <li>Mobile therapists — home, school &amp; workplace visits</li>
          <li>Experienced with both NDIS and private clients</li>
          <li>Paediatrics through to adults</li>
        </ul>
      </div>

      <div class="hero-media">
        <img
          src="/images/hero.svg"
          alt="Placeholder image of an occupational therapy session"
          width="1200"
          height="1000"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- ============================= ABOUT ============================= -->
  <section id="about" class="section section--tint">
    <div class="container about-grid">
      <div>
        <span class="eyebrow">About Pink Wattle</span>
        <h2>Friendly, practical therapy in the places that matter</h2>
      </div>
      <div class="about-copy">
        <p>
          We’re a Perth-based team of experienced occupational therapists who
          believe therapy works best in real-life settings. Rather than asking
          you to come to a clinic, we come to you — meeting you in your home,
          school, workplace or community.
        </p>
        <p>
          From early childhood through to adulthood, we support people of all
          ages and abilities across the full breadth of occupational therapy.
          Whether you’re funded through the NDIS or arranging private therapy,
          you’ll work with a therapist who takes the time to understand your
          goals and build a plan around them.
        </p>
        <div class="stat-row">
          <div class="stat">
            <strong>All ages</strong>
            <span>Paediatrics to adults</span>
          </div>
          <div class="stat">
            <strong>Mobile</strong>
            <span>We come to you</span>
          </div>
          <div class="stat">
            <strong>NDIS &amp; private</strong>
            <span>Flexible funding</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================= SERVICES ============================= -->
  <section id="services" class="section">
    <div class="container">
      <div class="section-intro">
        <span class="eyebrow">What we do</span>
        <h2>Occupational therapy across all disciplines</h2>
        <p>
          Our therapists support a wide range of needs and goals. Here are some
          of the areas we work in — if you don’t see what you’re looking for,
          just ask.
        </p>
      </div>

      <div class="card-grid">
        {
          services.map((service) => (
            <article class="card">
              <span class="card-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6 9 17l-5-5" />
                </svg>
              </span>
              <h3>{service.title}</h3>
              <p>{service.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============================= WHO WE HELP ============================= -->
  <section id="who-we-help" class="section section--tint">
    <div class="container who-grid">
      <div class="who-media">
        <img
          src="/images/banner.svg"
          alt="Placeholder banner image"
          width="1600"
          height="600"
        />
      </div>
      <div class="who-copy">
        <span class="eyebrow">Who we help</span>
        <h2>Support for every stage of life</h2>
        <p>
          We work with individuals and families across Perth — wherever you are
          on your journey, and whatever your goals look like.
        </p>
        <ul class="who-list">
          <li><strong>Children</strong> — play, learning, school readiness and daily routines.</li>
          <li><strong>Young adults</strong> — navigating the transition to independence, study and work.</li>
          <li><strong>Adults</strong> — independence at home, in study, at work and in the community.</li>
        </ul>
        <a href="/contact" class="btn btn--primary">Talk to our team</a>
      </div>
    </div>
  </section>

  <!-- ============================= HOW IT WORKS ============================= -->
  <section class="section">
    <div class="container">
      <div class="section-intro">
        <span class="eyebrow">How it works</span>
        <h2>Getting started is simple</h2>
      </div>
      <ol class="steps">
        {
          steps.map((step, i) => (
            <li class="step">
              <span class="step-number">{i + 1}</span>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ============================= TESTIMONIALS ============================= -->
  <section class="section section--tint">
    <div class="container">
      <div class="section-intro">
        <span class="eyebrow">Kind words</span>
        <h2>What our clients say</h2>
      </div>
      <div class="testimonial-grid">
        {
          testimonials.map((t) => (
            <figure class="testimonial">
              <span class="quote-mark" aria-hidden="true">“</span>
              <blockquote>{t.quote}</blockquote>
              <figcaption>{t.name}</figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============================= CTA BANNER ============================= -->
  <section class="cta-banner">
    <div class="container cta-inner">
      <div>
        <h2>Ready to take the first step?</h2>
        <p>
          Tell us a little about your situation and we’ll be in touch to talk
          through how we can help.
        </p>
      </div>
      <div class="cta-actions">
        <a href="/contact" class="btn btn--primary">Contact us</a>
        <a href={`mailto:${SITE.email}`} class="cta-email">{SITE.email}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Hero ---- */
  .hero {
    background: linear-gradient(
      180deg,
      var(--color-background) 0%,
      var(--color-white) 100%
    );
    padding-block: clamp(3rem, 7vw, 5.5rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .hero-copy .tag {
    margin-bottom: 1.25rem;
  }

  .hero-lead {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    margin-top: 1.25rem;
    max-width: 52ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }

  .hero-points {
    list-style: none;
    padding: 0;
    margin-top: 2rem;
    display: grid;
    gap: 0.65rem;
  }

  .hero-points li {
    position: relative;
    padding-left: 1.85rem;
    color: var(--color-text);
    font-weight: 500;
  }

  .hero-points li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.45rem;
    width: 1.1rem;
    height: 1.1rem;
    border-radius: 50%;
    background-color: var(--color-accent);
    box-shadow: 0 0 0 4px var(--color-accent-soft);
  }

  .hero-media img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  /* ---- About ---- */
  .about-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;
  }

  .about-copy p + p {
    margin-top: 1.1rem;
  }

  .about-copy p {
    color: var(--color-text-muted);
    font-size: 1.075rem;
  }

  .stat-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    padding: 1rem 1.4rem;
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    min-width: 150px;
  }

  .stat strong {
    color: var(--color-primary);
    font-size: 1.15rem;
  }

  .stat span {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  /* ---- Cards ---- */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: var(--color-accent-soft);
    color: var(--color-accent);
    margin-bottom: 1.1rem;
  }

  .card h3 {
    margin-bottom: 0.5rem;
  }

  .card p {
    color: var(--color-text-muted);
  }

  /* ---- Who we help ---- */
  .who-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .who-media img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .who-copy p {
    color: var(--color-text-muted);
    font-size: 1.075rem;
    margin-top: 0.5rem;
  }

  .who-list {
    list-style: none;
    padding: 0;
    margin: 1.75rem 0;
    display: grid;
    gap: 0.85rem;
  }

  .who-list li {
    position: relative;
    padding-left: 1.85rem;
    color: var(--color-text-muted);
  }

  .who-list li strong {
    color: var(--color-text);
  }

  .who-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55rem;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    background-color: var(--color-primary);
  }

  /* ---- Steps ---- */
  .steps {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    counter-reset: step;
  }

  .step {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.75rem;
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--color-primary);
    color: var(--color-white);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .step h3 {
    margin-bottom: 0.4rem;
  }

  .step p {
    color: var(--color-text-muted);
  }

  /* ---- Testimonials ---- */
  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .testimonial {
    position: relative;
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 2rem 1.75rem 1.75rem;
    margin: 0;
  }

  .quote-mark {
    position: absolute;
    top: 0.4rem;
    left: 1.25rem;
    font-size: 3.5rem;
    line-height: 1;
    color: var(--color-secondary);
    font-family: Georgia, 'Times New Roman', serif;
  }

  .testimonial blockquote {
    position: relative;
    margin: 0 0 1.1rem;
    color: var(--color-text);
    font-size: 1.05rem;
    font-style: italic;
  }

  .testimonial figcaption {
    font-weight: 600;
    color: var(--color-accent);
    font-size: 0.9rem;
  }

  /* ---- CTA banner ---- */
  .cta-banner {
    background: linear-gradient(
      120deg,
      var(--color-primary) 0%,
      var(--color-primary-dark) 100%
    );
    color: var(--color-white);
  }

  .cta-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .cta-banner h2 {
    color: var(--color-white);
  }

  .cta-inner p {
    margin-top: 0.5rem;
    max-width: 46ch;
    color: rgba(255, 255, 255, 0.9);
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.85rem;
  }

  .cta-banner .btn--primary {
    background-color: var(--color-white);
    color: var(--color-primary);
  }

  .cta-banner .btn--primary:hover {
    background-color: var(--color-background);
    color: var(--color-primary-dark);
  }

  .cta-email {
    color: var(--color-white);
    font-weight: 600;
    text-decoration: underline;
  }

  .cta-email:hover {
    color: var(--color-background);
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .hero-grid,
    .about-grid,
    .who-grid {
      grid-template-columns: 1fr;
    }

    .hero-media {
      order: -1;
    }

    .who-media {
      order: -1;
    }
  }
</style>
